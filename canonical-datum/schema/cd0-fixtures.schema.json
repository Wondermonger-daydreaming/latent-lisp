{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://latent-lisp.example/cd0-fixtures.schema.json",
  "title": "Lisp+ Canonical Datum /0 shared fixture rows",
  "$defs": {
    "decimalInteger": {"type":"string","pattern":"^-?(0|[1-9][0-9]*)$"},
    "hexOctets": {"type":"string","pattern":"^(?:[0-9a-f]{2})*$"},
    "id": {
      "type":"object",
      "required":["t","namespace_utf8_hex","path_utf8_hex"],
      "properties":{
        "t":{"const":"id"},
        "namespace_utf8_hex":{"type":"array","items":{"type":"string","pattern":"^(?:[0-9a-f]{2})+$"}},
        "path_utf8_hex":{"type":"array","minItems":1,"items":{"type":"string","pattern":"^(?:[0-9a-f]{2})+$"}}
      },
      "additionalProperties":false
    },
    "datum": {
      "oneOf":[
        {"type":"object","required":["t"],"properties":{"t":{"const":"unit"}},"additionalProperties":false},
        {"type":"object","required":["t","v"],"properties":{"t":{"const":"bool"},"v":{"type":"boolean"}},"additionalProperties":false},
        {"type":"object","required":["t","v"],"properties":{"t":{"const":"int"},"v":{"$ref":"#/$defs/decimalInteger"}},"additionalProperties":false},
        {"type":"object","required":["t","p","q"],"properties":{"t":{"const":"rat"},"p":{"$ref":"#/$defs/decimalInteger"},"q":{"$ref":"#/$defs/decimalInteger"}},"additionalProperties":false},
        {"type":"object","required":["t","utf8_hex"],"properties":{"t":{"const":"string"},"utf8_hex":{"$ref":"#/$defs/hexOctets"}},"additionalProperties":false},
        {"type":"object","required":["t","hex"],"properties":{"t":{"const":"bytes"},"hex":{"$ref":"#/$defs/hexOctets"}},"additionalProperties":false},
        {"$ref":"#/$defs/id"},
        {"type":"object","required":["t","items"],"properties":{"t":{"const":"seq"},"items":{"type":"array","items":{"$ref":"#/$defs/datum"}}},"additionalProperties":false},
        {"type":"object","required":["t","fields"],"properties":{"t":{"const":"record"},"fields":{"type":"array","items":{"type":"object","required":["key","value"],"properties":{"key":{"$ref":"#/$defs/id"},"value":{"$ref":"#/$defs/datum"}},"additionalProperties":false}}},"additionalProperties":false}
      ]
    },
    "failure": {
      "type":"object",
      "required":["category","code","stage"],
      "properties":{
        "category":{"enum":["InvalidCanonicalGrammar","NoncanonicalEncoding","UnsupportedFormat","ResourceRefusal","UnsupportedHostInput","PrivilegedRestorationAttempt","InternalInvariantFailure"]},
        "code":{"type":"string","minLength":1},
        "stage":{"enum":["input-budget","magic","version-varint","version-selection","type-tag","integer-payload","rational-payload","length","count","utf8","identifier","record-key","record-order","container-content","end-of-input","host-import","encode-ordering","allocation","cache-check","internal"]}
      },
      "additionalProperties":false
    },
    "positive": {
      "type":"object",
      "required":["id","datum_version","abstract","canonical_hex","expected_decoded","equality_class","budget","notes"],
      "properties":{
        "id":{"type":"string"},"datum_version":{"const":0},"abstract":{"$ref":"#/$defs/datum"},
        "canonical_hex":{"$ref":"#/$defs/hexOctets"},"diagnostic":{"type":"string"},
        "expected_decoded":{"$ref":"#/$defs/datum"},"equality_class":{"type":"string"},
        "budget":{"type":"string"},"notes":{"type":"array","items":{"type":"string"}}
      },
      "additionalProperties":false
    },
    "negative": {
      "type":"object",
      "required":["id","input_kind","input_hex","budget","expected_failure","input_classification","resource_state_unchanged","partial_output_forbidden","notes"],
      "properties":{
        "id":{"type":"string"},"input_kind":{"const":"octets"},"input_hex":{"$ref":"#/$defs/hexOctets"},
        "budget":{"type":"string"},"expected_failure":{"$ref":"#/$defs/failure"},
        "input_classification":{"enum":["invalid","noncanonical","unsupported","resource","privileged"]},
        "resource_state_unchanged":{"const":true},"partial_output_forbidden":{"const":true},
        "notes":{"type":"array","items":{"type":"string"}}
      },
      "additionalProperties":false
    }
  }
}
