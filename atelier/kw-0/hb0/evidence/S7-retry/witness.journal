(:EV :START :PROC "p1")
(:EV :SEAT :SEAT "alpha")
(:EV :ATTEMPT :ID "a1" :OP "bank-write")
(:EV :DISPATCH :ID "a1")
(:EV :EVIDENCE :ID "a1" :KIND :PROVIDER-RECEIPT :SETTLEMENT "not-executed")
(:EV :ATTEMPT :ID "a2" :OP "bank-write" :RETRY-OF "a1")
(:EV :DISPATCH :ID "a2")
(:EV :RESULT :ID "a2" :STATUS :EXECUTED :PAYLOAD :ABSENT)
(:EV :RECEIPT :ID "a2")
