+;; Selection pays explicitly for syntax.  Raw error remains stored in ORG-ERR
+;; and reported on its own; this score must never be presented as prediction
+;; error.
+(defparameter *parsimony-lambda* 0.001d0)
+
+(defun fitness-score (tree data &optional raw)
+  "Penalized selection score = raw error + lambda times node count."
+  (+ (or raw (raw-error tree data))
+     (* *parsimony-lambda* (tree-size tree))))
+
 (defun hits (tree data &optional (tol 0.01d0))
   (loop for (x . y) in data count (< (abs (- (tree-eval tree x) y)) tol)))
 
